# server/.env.example — 複製為 server/.env 並填實際值（server/.env 已列入 .gitignore，
# 不會進 repo）。零 npm 依賴的極簡解析（server/config.js）：KEY=VALUE，'#' 開頭整行是註解，
# 不支援變數展開。

# 監聽埠（必填）。dev 實例用 8790、prod 實例用 8789（同一台機器跑兩個實例，埠號要分開）。
PORT=8790

# 監聽位址。預設 127.0.0.1（只給本機的反向代理/防火牆轉接）；若要讓區網直接連這台機器，
# 改成 0.0.0.0（連同防火牆規則一起考慮，不要無腦開）。
BIND=127.0.0.1

# GAS 本體檔案路徑（相對 repo 根）。這個檔案會被 node:vm 原封不動載入執行——
# 一律指向 dev/Code.gs 或 Code.gs，不要指向 server/ 底下任何檔案。
GS_FILE=dev/Code.gs

# 前端單檔路徑（相對 repo 根）。build-public.js 讀這個檔案產出可自架部署的版本。
FRONTEND_FILE=dev/index.html

# 這台伺服器對外可被瀏覽器打到的完整 origin（含 port、不含結尾斜線）。
# build-public.js 會把前端的 APPS_SCRIPT_URL 換成 SERVER_ORIGIN + '/exec'。
SERVER_ORIGIN=http://192.168.100.123:8790

# 資料目錄（相對 repo 根，或給絕對路徑）。存放 store/、attachments/、props.json、
# users.json、sessions 等全部持久化資料——這是整個系統的「資料庫」，務必納入備份，
# 且已列入 .gitignore（含個資，絕對不可進 repo）。
DATA_DIR=server/data

# 靜態檔輸出目錄（相對 repo 根，或給絕對路徑）。build-public.js 的輸出、index.js 的靜態
# 服務都指向這裡。已列入 .gitignore（是建置產物，不是原始碼，不進 repo）。
PUBLIC_DIR=server/public

# 登入節流窗口（毫秒）。連續登入失敗達 5 次後，此毫秒數內一律拒絕（不透露剩餘秒數）。
# 正式環境建議維持預設 60000（1 分鐘）；smoke.mjs 冒煙測試會覆寫成更短的值加速跑測試。
LOGIN_THROTTLE_MS=60000

# ── prod 實例參考值（另開一份 server/.env，實際部署時把上面的值換成這組）──────────
# PORT=8789
# GS_FILE=Code.gs
# FRONTEND_FILE=index.html
# SERVER_ORIGIN=http://192.168.100.123:8789
